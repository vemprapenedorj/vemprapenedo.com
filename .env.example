# Variaveis publicas do frontend devem usar o prefixo VITE_.
# Nunca adicione chaves privadas ou credenciais: tudo que entra no build do
# navegador pode ser inspecionado pelo visitante.
VITE_SITE_URL="https://vemprapenedo.com.br"

# Variáveis privadas do processo de build (não são expostas ao navegador).
# Ambientes de teste devem manter false. Use true apenas no deploy oficial .com.br.
SITE_URL="https://vemprapenedo.com.br"
ALLOW_INDEXING="false"

# Opcional: use true quando o ambiente de build não disponibilizar Chromium.
# O site continuará funcional, mas sem as páginas HTML pré-renderizadas.
SKIP_PRERENDER="false"
